# Rust 构建产物
/target

# rustfmt 备份
**/*.rs.bk

# Windows 调试符号
*.pdb

# macOS
.DS_Store

# IDE
.idea/
.vscode/

# Claude Code 本地会话状态（运行时，不入库）
/.claude/

# LRA 运行时产物（任务定义/状态/模板入库，运行时锁与报告不入库）
.long-run-agent/locks.json
.long-run-agent/records/
.long-run-agent/backup/
.long-run-agent/reports/

# LRA 运行时状态（每次跑都变，不入库）
.long-run-agent/quality_report.json
.long-run-agent/task_list.json

# 原始审计输出（瞬态，不入库；保留 .md 报告）
.boundary-audit/miri_output.txt
